# Test environment — used by `npm test`
# Copy to `.env.test` and adjust as needed.
# `.env.test` is gitignored.

# Test database (separate from dev!)
DATABASE_URL="postgresql://chao:chao_secret_2025@localhost:5432/chao_os_test?schema=public"

# NextAuth — test secret (32+ chars, NOT a real secret)
NEXTAUTH_SECRET="chao-os-test-secret-not-for-production-32chars-min"
NEXTAUTH_URL="http://localhost:3000"

# Other services — leave empty for tests (features that need them are skipped)
ANTHROPIC_API_KEY=""
RESEND_API_KEY=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Override app URL to a stable test value
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="CHAO OS (test)"
